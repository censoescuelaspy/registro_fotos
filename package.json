{
  "name": "cialpa-registro-fotos",
  "version": "1.0.4",
  "private": true,
  "description": "PWA para registrar y vincular fotografias del relevamiento escolar CIALPA.",
  "scripts": {
    "vendor": "node tools/copy-vendor.mjs",
    "catalog": "python tools/build_school_catalog.py",
    "serve": "npx http-server . -p 4173 -c-1",
    "test": "playwright test",
    "test:ui": "playwright test --ui"
  },
  "dependencies": {
    "leaflet": "1.9.4",
    "lucide": "0.468.0"
  },
  "devDependencies": {
    "@playwright/test": "1.49.1",
    "http-server": "14.1.1"
  }
}
